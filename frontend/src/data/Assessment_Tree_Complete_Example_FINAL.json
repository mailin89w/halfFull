    "modules": [
      {
        "id": "pre_assessment",
        "title": "Pre-Assessment",
        "description": "Lab status gate - determines which assessment path you take",
        "icon": "\ud83e\uddea",
        "order": 0,
        "shown_in_paths": [
          "full",
          "hybrid"
        ],
        "questions": [
          {
            "id": "q0.0",
            "text": "Do you have recent lab results (from the last 6 months)?",
            "help_text": "If you've had blood work done recently, you can upload it and we'll analyze it immediately. This speeds up your assessment and gives us more precise results. If not, no worries\u2014we'll guide you on which tests you need.",
            "type": "binary",
            "feature_name": "has_recent_labs",
            "options": [
              {
                "value": "lab_yes",
                "label": "Yes, I have recent labs"
              },
              {
                "value": "lab_no",
                "label": "No, I don't have recent labs"
              }
            ],
            "validation": {
              "required": true
            },
            "routing": {
              "path_determination": [
                {
                  "answer_value": "lab_yes",
                  "determines_path": "hybrid",
                  "next_step": "q0.1"
                },
                {
                  "answer_value": "lab_no",
                  "determines_path": "full",
                  "next_step": "q1.1"
                }
              ]
            }
          },
          {
            "id": "q0.1",
            "text": "Upload your lab results (PDF, JPG, or PNG)",
            "help_text": "Upload any recent blood work. We'll extract values for ferritin, TSH, B12, hemoglobin, and other relevant markers. You can also manually enter values if OCR doesn't work perfectly.",
            "type": "file_upload",
            "feature_name": "uploaded_lab_values",
            "options": [
              {
                "value": "file_upload",
                "label": "Upload file or enter manually"
              }
            ],
            "conditional": {
              "parent_id": "q0.0",
              "parent_values": [
                "lab_yes"
              ],
              "condition_type": "equals"
            },
            "validation": {
              "required": true,
              "accepted_formats": [
                "application/pdf",
                "image/jpeg",
                "image/png"
              ],
              "max_file_size_mb": 10
            },
            "processing": {
              "method": "ocr_extraction_fallback_to_manual",
              "extracts": [
                "ferritin",
                "tsh",
                "free_t4",
                "hemoglobin",
                "hematocrit",
                "vitamin_b12",
                "folate",
                "vitamin_d",
                "serum_iron",
                "tibc"
              ]
            },
            "routing": {
              "triggers_pathway": [
                {
                  "lab_value": "ferritin",
                  "if_below": 30,
                  "pathway_id": "iron_deficiency",
                  "priority": "high"
                },
                {
                  "lab_value": "tsh",
                  "if_above": 4.5,
                  "pathway_id": "thyroid_dysfunction",
                  "priority": "high"
                },
                {
                  "lab_value": "vitamin_b12",
                  "if_below": 200,
                  "pathway_id": "b12_deficiency",
                  "priority": "high"
                }
              ],
              "skips_questions": [
                "q2.1",
                "q2.2",
                "q2.3",
                "q2.4",
                "q2.5",
                "q3.1",
                "q3.2",
                "q3.3",
                "q3.4",
                "q3.5",
                "q3.6"
              ],
              "next_questions": [
                "q1.1",
                "q1.2",
                "q1.3",
                "q1.4",
                "q1.5",
                "q4.1",
                "q4.2",
                "q4.3",
                "q4.4",
                "q4.5",
                "q5.1",
                "q5.2",
                "q5.3",
                "q5.4",
                "q5.5"
              ]
            }
          }
        ]
      },
